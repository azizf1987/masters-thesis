{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://epic-board.dev/roadmap.schema.json",
  "title": "Epic Board roadmap",
  "type": "object",
  "required": ["version", "phases"],
  "additionalProperties": true,
  "definitions": {
    "assignee": {
      "enum": ["ai", "me", "ai+verify"],
      "description": "Who owns the work. ai = AI end to end, me = human only (accounts, certs, legal, device tests), ai+verify = AI builds, human verifies."
    },
    "date": {
      "oneOf": [
        { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        { "type": "null" }
      ]
    },
    "label": { "type": "string", "minLength": 1 },
    "task": {
      "type": "object",
      "required": ["id", "title", "status"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z0-9.]+-T[0-9]+$" },
        "title": { "type": "string", "minLength": 1 },
        "status": { "enum": ["todo", "doing", "done"] },
        "assignee": { "$ref": "#/definitions/assignee" },
        "labels": { "type": "array", "items": { "$ref": "#/definitions/label" } },
        "planned": { "$ref": "#/definitions/date" },
        "note": { "type": "string" }
      }
    },
    "epic": {
      "type": "object",
      "required": ["id", "title", "status", "assignee", "goal", "exit"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z0-9.]+$" },
        "title": { "type": "string", "minLength": 1 },
        "emoji": { "type": "string" },
        "status": { "enum": ["backlog", "next", "active", "blocked", "done"] },
        "assignee": { "$ref": "#/definitions/assignee" },
        "labels": { "type": "array", "items": { "$ref": "#/definitions/label" } },
        "planned": { "$ref": "#/definitions/date" },
        "shipped": { "$ref": "#/definitions/date" },
        "order": { "type": "integer", "minimum": 0 },
        "phase": { "type": "string" },
        "goal": { "type": "string", "minLength": 1 },
        "exit": { "type": "string", "minLength": 1 },
        "body": { "type": "string", "description": "Relative path to a markdown body, e.g. epics/E1.26.md" },
        "tasks": { "type": "array", "items": { "$ref": "#/definitions/task" } }
      }
    },
    "phase": {
      "type": "object",
      "required": ["id", "title", "status", "epics"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string", "minLength": 1 },
        "emoji": { "type": "string" },
        "status": { "enum": ["planned", "active", "done"] },
        "goal": { "type": "string" },
        "exit": { "type": "string" },
        "epics": { "type": "array", "items": { "$ref": "#/definitions/epic" } }
      }
    }
  },
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "integer", "const": 1 },
    "project": { "type": "string" },
    "updated": { "$ref": "#/definitions/date" },
    "phases": { "type": "array", "items": { "$ref": "#/definitions/phase" } }
  }
}
